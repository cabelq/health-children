# ============================================================
# SaludInfantil Server — configuración
# ============================================================
# Copiá este archivo a `.env` y editá los valores.

# Puerto HTTP
PORT=3000

# Entorno: 'development' o 'production'
NODE_ENV=development

# Clave secreta para firmar JWT (HS256).
# IMPORTANTE: en producción generá una con `openssl rand -hex 64`
JWT_SECRET=cambiar-en-produccion-usar-openssl-rand-hex-64

# Duración del access token (segundos). 15 min = 900
JWT_EXPIRES_IN=900

# Duración del refresh token (segundos). 7 días = 604800
JWT_REFRESH_EXPIRES_IN=604800

# Path a la DB SQLite del server (donde guardamos users + blobs cifrados)
DB_PATH=./data/server.sqlite

# Tamaño máximo del blob cifrado (bytes). Default: 50MB.
MAX_BLOB_SIZE=52428800

# CORS — orígenes permitidos (separados por coma). Usá * solo en dev.
CORS_ORIGINS=*

# Rate limit básico (requests por minuto por IP)
RATE_LIMIT=120